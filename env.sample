# TradingAgents Environment Configuration
# ======================================
# Instructions:
# 1. Copy this file to ".env".
# 2. Replace placeholder values with your own keys.
# 3. Restart the CLI/WebUI after changing this file.
#
# Keep ALPACA_USE_PAPER=True while testing. Set it to False only when you
# intentionally want live Alpaca trading.


# ---------------------------------------------------------------------------
# Runtime Paths
# ---------------------------------------------------------------------------

# Optional. Defaults to "eval_results".
TRADINGAGENTS_RESULTS_DIR=eval_results

# Optional. Defaults to tradingagents/dataflows/data_cache.
TRADINGAGENTS_CACHE_DIR=tradingagents/dataflows/data_cache

# Optional. Defaults to ~/.tradingagents/memory/trading_memory.md.
TRADINGAGENTS_MEMORY_LOG_PATH=~/.tradingagents/memory/trading_memory.md

# Optional. Override selected bundled model prompt templates with Markdown files.
# Keep grouped paths, for example analysts/market_system.md.
# Missing files fall back to tradingagents/prompts/templates.
TRADINGAGENTS_PROMPT_DIR=


# ---------------------------------------------------------------------------
# LLM Provider Selection
# ---------------------------------------------------------------------------

# Supported values:
# openai, local_openai, google, anthropic, xai, deepseek, qwen, glm,
# openrouter, ollama, azure
LLM_PROVIDER=openai


# ---------------------------------------------------------------------------
# OpenAI and Local OpenAI-Compatible Endpoints
# ---------------------------------------------------------------------------

# Required for OpenAI models and OpenAI web-search data tools.
# Also used by memory embeddings unless OPENAI_USE_LOCAL points embeddings to
# a compatible local endpoint.
OPENAI_API_KEY=your_openai_api_key_here

# Set true to route core LLM and embedding calls to OPENAI_BASE_URL.
# OpenAI web-search tools still require OPENAI_API_KEY because local endpoints
# usually do not support OpenAI Responses web search.
OPENAI_USE_LOCAL=false

# Examples:
# LM Studio: http://localhost:1234/v1
# Ollama OpenAI compatibility: http://localhost:11434/v1
# vLLM OpenAI server: http://localhost:8000/v1
OPENAI_BASE_URL=http://localhost:1234/v1

# Optional embedding model override for memory.
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002


# ---------------------------------------------------------------------------
# Non-OpenAI LLM Providers
# ---------------------------------------------------------------------------

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# xAI Grok
XAI_API_KEY=your_xai_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Alibaba Qwen via DashScope OpenAI-compatible endpoint
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Zhipu GLM
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama does not require an API key by default. Use backend_url in the UI/CLI
# or OPENAI_BASE_URL with LLM_PROVIDER=local_openai for OpenAI compatibility.


# ---------------------------------------------------------------------------
# Azure OpenAI
# ---------------------------------------------------------------------------

AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-12-01-preview


# ---------------------------------------------------------------------------
# Trading, Market Data, News, and Macro APIs
# ---------------------------------------------------------------------------

# Alpaca is required for live market data and order execution.
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_USE_PAPER=True

# Finnhub is used for equity news, insider sentiment/transactions, and
# earnings calendar data.
FINNHUB_API_KEY=your_finnhub_api_key_here

# FRED is used by the macro analyst.
FRED_API_KEY=your_fred_api_key_here

# CryptoCompare/CoinDesk-compatible news source used for crypto analysis.
COINDESK_API_KEY=your_cryptocompare_api_key_here

# Optional fallback market data source.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
